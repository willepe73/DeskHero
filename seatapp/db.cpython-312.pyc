from __future__ import annotations

from datetime import date as dt_date
from datetime import datetime as dt_datetime

from pydantic import BaseModel, Field


class ReservationCreate(BaseModel):
    building: str = Field(min_length=1, examples=["Agora"])
    floor: int = Field(ge=0, examples=[1])
    seat_number: int = Field(ge=0, examples=[401])
    date: dt_date = Field(examples=["2025-12-17"])
    reserved_by: str | None = Field(default=None, examples=["alice"])


class ReservationOut(BaseModel):
    id: str
    building: str
    floor: int
    seat_number: int
    date: dt_date
    reserved_by: str | None
    created_at: dt_datetime


class FloorOut(BaseModel):
    floor: int
    floorplan_url: str | None = None


class BuildingOut(BaseModel):
    name: str
    floors: list[FloorOut]


class SeatAvailabilityOut(BaseModel):
    seat_number: int
    is_reserved: bool
    # Optional normalized coordinates (0..1) for overlay placement on floorplan image.
    x: float | None = None
    y: float | None = None


class AvailabilityOut(BaseModel):
    building: str
    floor: int
    date: dt_date
    floorplan_url: str | None = None
    image_width: int | None = None
    image_height: int | None = None
    seats: list[SeatAvailabilityOut]


