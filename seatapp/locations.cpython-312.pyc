from __future__ import annotations

import json
from datetime import date
from pathlib import Path
from urllib.parse import quote

from fastapi import APIRouter, Depends, HTTPException
from fastapi.responses import FileResponse
from sqlalchemy import func, select
from sqlalchemy.orm import Session

from ..db import get_session
from ..models import Building, Floor, Reservation, Seat
from ..schemas import (
    AvailabilityOut,
    BuildingOut,
    FloorOut,
    SeatAvailabilityOut,
)
from ..settings import settings

router = APIRouter(tags=["locations"])

def _load_seat_registry_cache() -> dict:
    try:
        p = Path(settings.seat_registry_cache_path)
        if not p.exists():
            return {}
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _seat_center_normalized(cache_entry: dict, seat_number: int) -> tuple[float | None, float | None]:
    try:
        boxes = cache_entry.get("seat_boxes") or {}
        b = boxes.get(str(seat_number)) or boxes.get(seat_number)
        if not b:
            return None, None
        iw = cache_entry.get("image_width")
        ih = cache_entry.get("image_height")
        if not iw or not ih:
            return None, None
        left = float(b["left"])
        top = float(b["top"])
        width = float(b["width"])
        height = float(b["height"])
        x = (left + width / 2.0) / float(iw)
        y = (top + height / 2.0) / float(ih)
        if x < 0 or x > 1 or y < 0 or y > 1:
            return None, None
        return x, y
    except Exception:
        return None, None


@router.get("/locations", response_model=list[BuildingOut])
def list_locations(db: Session = Depends(get_session)) -> list[BuildingOut]:
    buildings = list(db.scalars(select(Building).order_by(func.lower(Building.name))).all())
    out: list[BuildingOut] = []
    for b in buildings:
        b_q = quote(b.name)
        floors = list(
            db.scalars(
                select(Floor)
                .where(Floor.building_id == b.id)
                .order_by(Floor.floor_number.asc())
            ).all()
        )
        out.append(
            BuildingOut(
                name=b.name,
                floors=[
                    FloorOut(
                        floor=f.floor_number,
                        floorplan_url=(
                            f"{settings.api_prefix}/floorplan?building={b_q}&floor={f.floor_number}"
                            if f.floorplan_file
                            else None
                        ),
                    )
                    for f in floors
                ],
            )
        )
    return out


@router.get("/floorplan")
def get_floorplan(building: str, floor: int, db: Session = Depends(get_session)) -> FileResponse:
    b = db.scalar(select(Building).where(func.lower(Building.name) == building.lower()))
    if not b:
        raise HTTPException(status_code=404, detail="Unknown building")

    f = db.scalar(
        select(Floor).where(Floor.building_id == b.id, Floor.floor_number == floor)
    )
    if not f:
        raise HTTPException(status_code=404, detail="Unknown floor")
    if not f.floorplan_file:
        raise HTTPException(status_code=404, detail="Floorplan not available")

    image_path = Path(settings.floorplans_dir) / f.floorplan_file
    if not image_path.exists():
        raise HTTPException(status_code=404, detail="Floorplan file missing on server")

    return FileResponse(path=image_path, media_type="image/png")


@router.get("/availability", response_model=AvailabilityOut)
def seat_availability(
    building: str,
    floor: int,
    date: date,
    db: Session = Depends(get_session),
) -> AvailabilityOut:
    b = db.scalar(select(Building).where(func.lower(Building.name) == building.lower()))
    if not b:
        raise HTTPException(status_code=404, detail="Unknown building")

    f = db.scalar(
        select(Floor).where(Floor.building_id == b.id, Floor.floor_number == floor)
    )
    if not f:
        raise HTTPException(status_code=404, detail="Unknown floor")

    seats = list(
        db.scalars(select(Seat).where(Seat.floor_id == f.id).order_by(Seat.seat_number.asc())).all()
    )

    reserved_seat_ids = set(
        db.scalars(
            select(Reservation.seat_id).where(Reservation.date == date, Reservation.seat_id.in_([s.id for s in seats]))
        ).all()
    )

    cache = _load_seat_registry_cache()
    cache_files = cache.get("files", {}) if isinstance(cache, dict) else {}
    cache_entry = cache_files.get(f.floorplan_file or "", {}) if f.floorplan_file else {}
    image_width = cache_entry.get("image_width")
    image_height = cache_entry.get("image_height")

    return AvailabilityOut(
        building=b.name,
        floor=f.floor_number,
        date=date,
        floorplan_url=(
            f"{settings.api_prefix}/floorplan?building={quote(b.name)}&floor={f.floor_number}"
            if f.floorplan_file
            else None
        ),
        image_width=image_width,
        image_height=image_height,
        seats=[
            (lambda x_y: SeatAvailabilityOut(
                seat_number=s.seat_number,
                is_reserved=s.id in reserved_seat_ids,
                x=x_y[0],
                y=x_y[1],
            ))(_seat_center_normalized(cache_entry, s.seat_number))
            for s in seats
        ],
    )


